PROJECT_ID="your-gcp-project-id"
REGION="europe-west2"
SERVICE_NAME="payments-service"
IMAGE="europe-west2-docker.pkg.dev/your-gcp-project-id/payments-service/payments-service:latest"
SERVICE_ACCOUNT="payments-service@your-gcp-project-id.iam.gserviceaccount.com"
CLOUD_SQL_INSTANCE="your-gcp-project-id:europe-west2:payments-service-db"
DATABASE_URL="postgres://payments_service:<password>@/<db>?host=/cloudsql/your-gcp-project-id:europe-west2:payments-service-db&sslmode=disable"
